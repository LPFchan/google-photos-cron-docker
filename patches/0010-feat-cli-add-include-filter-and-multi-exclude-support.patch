-func scanDirectoryForFiles(path string, recursive bool, excludePattern string) ([]string, error) {
+func scanDirectoryForFiles(path string, recursive bool, excludePattern string, includePattern string) ([]string, error) {
 	var files []string
+	excludePatterns := splitDirectoryPatterns(excludePattern)
+	includePatterns := splitDirectoryPatterns(includePattern)
+	rootPath := filepath.Clean(path)
 
-	entries, err := os.ReadDir(path)
-	if err != nil {
-		return nil, err
-	}
+	var scan func(string) error
+	scan = func(currentPath string) error {
+		entries, err := os.ReadDir(currentPath)
+		if err != nil {
+			return err
+		}
 
-	for _, entry := range entries {
-		fullPath := filepath.Join(path, entry.Name())
-		if entry.IsDir() {
-			if excludePattern != "" && entry.Name() == excludePattern {
-				continue
-			}
-			if recursive {
-				subFiles, err := scanDirectoryForFiles(fullPath, recursive, excludePattern)
+		for _, entry := range entries {
+			fullPath := filepath.Join(currentPath, entry.Name())
+			if entry.IsDir() {
+				relPath, err := filepath.Rel(rootPath, fullPath)
 				if err != nil {
+					relPath = entry.Name()
+				}
+				if matchesDirectoryPattern(relPath, excludePatterns) {
 					continue
 				}
-				files = append(files, subFiles...)
+				if recursive {
+					if err := scan(fullPath); err != nil {
+						continue
+					}
+				}
+			} else {
+				if len(includePatterns) > 0 {
+					relDir, err := filepath.Rel(rootPath, currentPath)
+					if err != nil || relDir == "." {
+						continue
+					}
+					if !matchesDirectoryPattern(relDir, includePatterns) {
+						continue
+					}
+				}
+				files = append(files, fullPath)
 			}
-		} else {
-			files = append(files, fullPath)
 		}
+
+		return nil
+	}
+
+	if err := scan(rootPath); err != nil {
+		return nil, err
 	}
 
 	return files, nil
 }
 
+func splitDirectoryPatterns(patterns string) []string {
+	if strings.TrimSpace(patterns) == "" {
+		return nil
+	}
+	parts := strings.Split(patterns, ",")
+	result := make([]string, 0, len(parts))
+	for _, part := range parts {
+		part = strings.Trim(strings.TrimSpace(part), string(filepath.Separator))
+		if part != "" {
+			result = append(result, part)
+		}
+	}
+	return result
+}
+
+func matchesDirectoryPattern(relPath string, patterns []string) bool {
+	relPath = filepath.Clean(relPath)
+	if relPath == "." || relPath == string(filepath.Separator) {
+		return false
+	}
+	for _, pattern := range patterns {
+		if relPath == pattern || strings.HasPrefix(relPath, pattern+string(filepath.Separator)) {
+			return true
+		}
+		for _, part := range strings.Split(relPath, string(filepath.Separator)) {
+			if part == pattern {
+				return true
+			}
+		}
+	}
+	return false
+}
